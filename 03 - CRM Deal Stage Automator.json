{
  "name": "03 - CRM Deal Stage Automator",
  "nodes": [
    {
      "parameters": {
        "options": {}
      },
      "id": "e8f161c7-a0dd-4f63-b61e-b96599b53091",
      "name": "Sales Inbox Trigger",
      "type": "n8n-nodes-base.emailReadImap",
      "typeVersion": 2,
      "position": [
        -1264,
        288
      ]
    },
    {
      "parameters": {
        "modelId": {
          "value": "gpt-4o-mini",
          "__rl": true,
          "mode": "id"
        },
        "messages": {
          "values": [
            {
              "content": "You are an email intent classifier for a sales team. Classify the email into EXACTLY one of these labels:\n- DEMO_REQUEST: prospect wants to see the product\n- PRICING_INQUIRY: asking about cost or plans\n- READY_TO_BUY: clear buying intent, wants to proceed\n- OBJECTION: raising concerns, hesitation, or friction\n- UNSUBSCRIBE: wants to stop communication\n- OTHER: anything that doesn't fit the above\n\nRespond with ONLY the label and a confidence score as JSON: {\"intent\": \"LABEL\", \"confidence\": 0.0-1.0, \"reasoning\": \"one sentence\"}",
              "role": "system"
            },
            {
              "content": "=Subject: {{ $json.subject }}\n\nBody: {{ $json.text?.substring(0, 2000) || $json.html?.replace(/<[^>]*>/g,'').substring(0, 2000) }}"
            }
          ]
        },
        "options": {
          "temperature": 0.1
        }
      },
      "id": "fb343538-d9c8-4560-bf20-b98612359992",
      "name": "Classify Intent",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        -1040,
        288
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const parsed = JSON.parse($json.message.content);\nconst fromEmail = $('Sales Inbox Trigger').item.json.from?.text?.match(/[\\w.-]+@[\\w.-]+\\.[a-z]+/)?.[0] || '';\nreturn { json: { intent: parsed.intent, confidence: parsed.confidence, reasoning: parsed.reasoning, from_email: fromEmail } };"
      },
      "id": "3b66ea80-4a11-4fcd-921b-1f0e425ab126",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -688,
        288
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "confidence-check",
              "leftValue": "={{ $json.confidence }}",
              "rightValue": 0.7,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c11639d7-5e61-4fff-b547-0df67e2d9b13",
      "name": "High Confidence?",
