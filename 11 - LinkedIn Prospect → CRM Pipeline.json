      "id": "1f9b5857-9b65-49d6-b995-1626381057d1",
      "name": "Fetch Phantombuster Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -944,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst outputUrl = response.output?.resultObject;\nif (!outputUrl) return [];\n\n// The output is usually a URL to the JSON file\n// If it's already an array, use it directly\nconst profiles = Array.isArray(response.output?.resultObject) \n  ? response.output.resultObject \n  : [];\n\nreturn profiles\n  .filter(p => p.firstName || p.first_name)\n  .map(p => ({\n    json: {\n      firstname: p.firstName || p.first_name || '',\n      lastname: p.lastName || p.last_name || '',\n      email: p.email || p.emailAddress || '',\n      jobtitle: p.occupation || p.title || p.jobTitle || '',\n      company: p.company || p.companyName || p.currentCompanyName || '',\n      linkedin_url: p.profileUrl || p.linkedinUrl || '',\n      location: p.location || p.locationName || '',\n      followers: p.followersCount || 0\n    }\n  }))\n  .filter(p => p.json.email || p.json.linkedin_url);\n"
      },
      "id": "fea401db-52d8-4464-956a-b45c1d9cc5c4",
      "name": "Parse & Normalise",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        240
      ]
    },
    {
      "parameters": {
        "url": "=https://api.hubapi.com/crm/v3/objects/contacts/{{ $json.email }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REPLACE_WITH_HUBSPOT_TOKEN"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
