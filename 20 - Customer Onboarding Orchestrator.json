    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COUNT(CASE WHEN profile_complete THEN 1 END) as profile_done,\n  COUNT(CASE WHEN first_import_done THEN 1 END) as import_done,\n  COUNT(CASE WHEN first_integration_done THEN 1 END) as integration_done,\n  COUNT(CASE WHEN first_report_done THEN 1 END) as report_done\nFROM onboarding_progress\nWHERE contact_id = '{{ $('New Customer Trigger').item.json.objectId }}';",
        "options": {}
      },
      "id": "8fb8f4e6-370b-446c-947c-c1099304ed1d",
      "name": "Check Milestones",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -1504,
        528
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const m = $json;\nconst milestones_completed = [m.profile_done, m.import_done, m.integration_done, m.report_done].filter(Boolean).length;\nconst on_track = milestones_completed >= 2;\nconst contact = $('Get Contact Details').item.json.properties;\nreturn {\n  json: {\n    on_track,\n    milestones_completed,\n    total_milestones: 4,\n    contact_email: contact.email?.value,\n    contact_firstname: contact.firstname?.value || 'there',\n    contact_id: $('New Customer Trigger').item.json.objectId,\n    deal_value: parseFloat(contact.dealvalue?.value || 0)\n  }\n};\n"
      },
      "id": "406ff4df-0f2a-47b3-8e54-5996b8ab3e15",
      "name": "Evaluate Progress",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        528
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
