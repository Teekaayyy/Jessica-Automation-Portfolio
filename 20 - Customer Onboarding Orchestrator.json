      "parameters": {
        "sendTo": "={{ $json.properties.email?.value }}",
        "subject": "=Welcome to {{ $env.PRODUCT_NAME || 'our platform' }}, {{ $json.properties.firstname?.value || 'there' }}! 🎉",
        "message": "=<html><body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333;\">\n<h2>Welcome, {{ $json.properties.firstname?.value || 'there' }}! 🎉</h2>\n<p>We're so excited to have you on board. Here's everything you need to get started:</p>\n<h3>Your first 3 steps:</h3>\n<ol>\n<li>✅ <strong>Complete your profile</strong> — takes 2 minutes</li>\n<li>📥 <strong>Import your first dataset</strong> — we'll walk you through it</li>\n<li>🔗 <strong>Connect your first integration</strong> — choose from 50+ tools</li>\n</ol>\n<p>Questions? Just reply to this email — we're here to help.</p>\n<p>Best,<br/>The {{ $env.PRODUCT_NAME || '' }} Team</p>\n</body></html>",
        "options": {}
      },
