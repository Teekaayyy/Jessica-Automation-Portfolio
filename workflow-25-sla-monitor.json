      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://YOUR_SUBDOMAIN.zendesk.com/api/v2/tickets.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Basic {{ Buffer.from($env.ZENDESK_EMAIL + '/token:' + $env.ZENDESK_API_TOKEN).toString('base64') }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "open,pending"
            },
            {
              "name": "sort_by",
              "value": "created_at"
            },
            {
              "name": "sort_order",
              "value": "asc"
            },
            {
              "name": "per_page",
              "value": "100"
            }
          ]
        },
        "options": {}
