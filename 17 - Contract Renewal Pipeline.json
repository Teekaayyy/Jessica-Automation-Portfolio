    {
      "parameters": {
        "sendTo": "={{ $env.RENEWAL_TEST_EMAIL || 'renewals@company.com' }}",
        "subject": "=Planning ahead — {{ $json.deal_name }} contract renewal",
        "emailType": "text",
        "message": "=Hi,\n\nI hope everything is going well. I'm writing to give you advance notice that your contract for {{ $json.deal_name }} is coming up for renewal in approximately 90 days ({{ $json.contract_end_date }}).\n\nThis early heads-up gives us plenty of time to review your needs and ensure continuity without any disruption.\n\nNo action needed right now — I'll be in touch closer to the date with renewal options. Feel free to reach out in the meantime.\n\nBest regards,\nAccount Management",
