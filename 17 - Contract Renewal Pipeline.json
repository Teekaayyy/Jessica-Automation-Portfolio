        "emailType": "text",
        "message": "=Hi,\n\nThis is an urgent reminder that the contract for {{ $json.deal_name }} expires in {{ $json.days_left }} days ({{ $json.contract_end_date }}).\n\nContract value: £{{ $json.amount }}\n\nPlease take immediate action to initiate the renewal process. Let me know if you'd like to discuss the terms.\n\nBest regards,\nAccount Management",
        "options": {}
