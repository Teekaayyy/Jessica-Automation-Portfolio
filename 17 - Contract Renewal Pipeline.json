            }
          ]
        }
      },
      "id": "2e893d83-3230-44ef-8066-efd15901d994",
      "name": "Daily 8:30am Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -432,
        128
      ]
    },
    {
      "parameters": {
        "resource": "deal",
        "operation": "getAll",
        "filters": {}
      },
      "id": "7a3299c8-b39b-4059-87c4-ad969a71c555",
      "name": "Query Expiring Contracts",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        -208,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst deals = $input.all().map(i => i.json);\n\nconst expiring = deals\n  .filter(d => d.properties?.contract_end_date)\n  .map(d => {\n    const endDate = new Date(d.properties.contract_end_date);\n    const daysLeft = Math.ceil((endDate - now) / (1000 * 60 * 60 * 24));\n    \n    let tier = null;\n    let already_sent_key = null;\n    if (daysLeft >= 28 && daysLeft <= 32) { tier = '30d'; already_sent_key = 'renewal_email_30d_sent'; }\n    else if (daysLeft >= 58 && daysLeft <= 62) { tier = '60d'; already_sent_key = 'renewal_email_60d_sent'; }\n    else if (daysLeft >= 88 && daysLeft <= 92) { tier = '90d'; already_sent_key = 'renewal_email_90d_sent'; }\n    \n    if (!tier) return null;\n    \n    const already_sent = d.properties?.[already_sent_key] === 'true';\n    if (already_sent) return null;\n    \n    return {\n      deal_id: d.id,\n      deal_name: d.properties.dealname || 'Unknown Deal',\n      amount: d.properties.amount || '0',\n      contract_end_date: d.properties.contract_end_date,\n      days_left: daysLeft,\n      tier,\n      already_sent_key,\n      owner_id: d.properties.hubspot_owner_id || ''\n    };\n  })\n  .filter(Boolean);\n\nreturn expiring.map(d => ({ json: d }));\n"
      },
      "id": "e9885176-0bc5-4e90-813f-c0ede16b6383",
      "name": "Segment by Tier",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
        128
      ]
    },
    {
      "parameters": {
        "rules": {
