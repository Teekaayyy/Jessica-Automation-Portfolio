            "Revenue": "={{ $json.total_revenue }}",
            "Conv_Rate": "={{ $json.conversion_rate }}"
          }
        },
        "options": {}
      },
      "id": "w38-9",
      "name": "Scorecard Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1520,
        420
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "content": "## 38 \u2014 Partner Performance Intelligence\n\n**HubSpot custom properties needed:**\n- contact_type (text \u2014 set to 'partner' for all partner contacts)\n- partner_company (text \u2014 the partner's company name, used for deal attribution)\n- partner_tier (text: Gold/Silver/Bronze/At Risk)\n- partner_score (number)\n- tier_updated_at (date)\n\n**Deal attribution:** Add a custom deal property 'partner_source' and require reps to populate it when creating partner-sourced deals.",
        "height": 220,
        "width": 380
      },
      "id": "w38-10",
      "name": "Setup Notes",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        200,
        560
      ]
    }
