    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst errors = [];\n\n// \u2500\u2500 HubSpot Pipeline Metrics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nlet open_deals = 0, pipeline_value = 0, deals_by_stage = {};\ntry {\n  const hs = items.find(i => i.json.results);\n  const deals = hs?.json?.results || [];\n  open_deals = deals.filter(d => !['closedwon','closedlost'].includes(d.properties?.dealstage?.value)).length;\n  pipeline_value = deals.reduce((s,d) => s + parseFloat(d.properties?.amount?.value || 0), 0);\n  deals.forEach(d => {\n    const stage = d.properties?.dealstage?.value || 'unknown';\n    deals_by_stage[stage] = (deals_by_stage[stage] || 0) + 1;\n  });\n} catch(e) { errors.push('hubspot: ' + e.message); }\n\n// \u2500\u2500 Stripe Revenue Metrics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nlet revenue_week = 0, transactions_week = 0;\ntry {\n  const stripe = items.find(i => i.json.data?.length && i.json.data[0]?.amount);\n  const charges = stripe?.json?.data || [];\n  transactions_week = charges.length;\n  revenue_week = charges.reduce((s,c) => s + (c.net || c.amount)/100, 0);\n} catch(e) { errors.push('stripe: ' + e.message); }\n\n// \u2500\u2500 Intercom Support Metrics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nlet new_conversations = 0, avg_first_response_mins = 0;\ntry {\n  const intercom = items.find(i => i.json.conversations);\n  const convos = intercom?.json?.conversations || [];\n  new_conversations = convos.length;\n  const responded = convos.filter(c => c.statistics?.first_response_time);\n  avg_first_response_mins = responded.length ? Math.round(responded.reduce((s,c) => s + (c.statistics.first_response_time/60), 0) / responded.length) : 0;\n} catch(e) { errors.push('intercom: ' + e.message); }\n\n// \u2500\u2500 GA4 Marketing Metrics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nlet sessions = 0, conversions = 0, new_users = 0;\ntry {\n  const ga4 = items.find(i => i.json.rows);\n  (ga4?.json?.rows || []).forEach(row => {\n    sessions += parseInt(row.metricValues[0].value || 0);\n    conversions += parseInt(row.metricValues[1].value || 0);\n    new_users += parseInt(row.metricValues[2].value || 0);\n  });\n} catch(e) { errors.push('ga4: ' + e.message); }\n\nconst now = new Date();\nconst metrics = {\n  // Timestamps\n  week_ending: now.toLocaleDateString('en-GB'),\n  generated_at: now.toISOString(),\n  // Pipeline\n  open_deals, pipeline_value: pipeline_value.toFixed(0),\n  // Revenue\n  revenue_week: revenue_week.toFixed(0), transactions_week,\n  // Support\n  new_conversations, avg_first_response_mins,\n  // Marketing\n  sessions_week: sessions, conversions_week: conversions, new_users_week: new_users,\n  conversion_rate: sessions > 0 ? ((conversions/sessions)*100).toFixed(2) : 0,\n  // Health\n  source_errors: errors, has_errors: errors.length > 0\n};\n\nreturn [{ json: metrics }];\n"
      },
