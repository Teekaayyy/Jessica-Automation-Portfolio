    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "value": "gpt-4o",
          "__rl": true,
          "mode": "id"
        },
        "messages": {
          "values": [
            {
              "content": "You are the Chief Revenue Officer writing a concise weekly business review. Be specific, data-driven, and decisive. Leadership does not have time for vague commentary \u2014 they need to know what happened, what it means, and what to do.\n\nStructure (4 short paragraphs):\n1. PERFORMANCE HEADLINE: One sentence capturing the week's most important story.\n2. GREEN LIGHTS: What improved and why it matters for the business.\n3. AMBER FLAGS: What needs attention and what's the likely cause.\n4. THIS WEEK'S PRIORITIES: 2-3 specific actions the team should take based on this data.\n\nTone: Direct, confident, no corporate filler.",
              "role": "system"
            },
            {
              "content": "=Week ending: {{ $json.week_ending }}\n\nMetrics:\n- Pipeline: {{ $json.open_deals }} open deals, \u00a3{{ parseInt($json.pipeline_value).toLocaleString() }} total value\n- Revenue: \u00a3{{ parseInt($json.revenue_week).toLocaleString() }} this week ({{ $json.transactions_week }} transactions)\n- Support: {{ $json.new_conversations }} new conversations, {{ $json.avg_first_response_mins }} min avg first response\n- Marketing: {{ $json.sessions_week }} sessions, {{ $json.conversions_week }} conversions, {{ $json.conversion_rate }}% CVR, {{ $json.new_users_week }} new users",
              "role": "user"
            }
          ]
        },
        "options": {
          "temperature": 0.4
        }
      },
