    {
      "parameters": {
        "sendTo": "={{ $env.LEADERSHIP_LIST }}",
        "subject": "=Weekly RevOps Brief \u2014 {{ $('Aggregate Metrics').first().json.week_ending }}",
        "emailType": "html",
        "message": "=<html><body style=\"font-family:Arial,sans-serif;max-width:700px;margin:0 auto;color:#333;\">\n<h2 style=\"color:#f97316;\">\ud83d\udcca Weekly RevOps Brief</h2>\n<p style=\"color:#888;\">Week ending {{ $('Aggregate Metrics').first().json.week_ending }} \u00b7 Auto-generated</p>\n<table style=\"width:100%;border-collapse:collapse;margin:20px 0;\">\n<tr style=\"background:#f5f5f5;\"><th style=\"padding:10px;text-align:left;\">Metric</th><th style=\"padding:10px;text-align:right;\">This Week</th></tr>\n<tr><td style=\"padding:8px;\">Open Deals</td><td style=\"padding:8px;text-align:right;\">{{ $('Aggregate Metrics').first().json.open_deals }}</td></tr>\n<tr style=\"background:#fafafa;\"><td style=\"padding:8px;\">Pipeline Value</td><td style=\"padding:8px;text-align:right;\">\u00a3{{ parseInt($('Aggregate Metrics').first().json.pipeline_value).toLocaleString() }}</td></tr>\n<tr><td style=\"padding:8px;\">Revenue</td><td style=\"padding:8px;text-align:right;\">\u00a3{{ parseInt($('Aggregate Metrics').first().json.revenue_week).toLocaleString() }}</td></tr>\n<tr style=\"background:#fafafa;\"><td style=\"padding:8px;\">Sessions</td><td style=\"padding:8px;text-align:right;\">{{ $('Aggregate Metrics').first().json.sessions_week }}</td></tr>\n<tr><td style=\"padding:8px;\">Conversions</td><td style=\"padding:8px;text-align:right;\">{{ $('Aggregate Metrics').first().json.conversions_week }} ({{ $('Aggregate Metrics').first().json.conversion_rate }}%)</td></tr>\n<tr style=\"background:#fafafa;\"><td style=\"padding:8px;\">Support Volume</td><td style=\"padding:8px;text-align:right;\">{{ $('Aggregate Metrics').first().json.new_conversations }} conversations</td></tr>\n</table>\n<hr/>\n<h3>Executive Summary</h3>\n<div style=\"line-height:1.7;font-size:15px;\">{{ $json.message.content.replace(/\\n/g,'<br>') }}</div>\n<hr/>\n<p style=\"color:#aaa;font-size:12px;\">RevOps Intelligence Dashboard \u00b7 Auto-generated weekly</p>\n</body></html>",
        "options": {}
      },
